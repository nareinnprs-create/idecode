{
  "private": false,
  "name": "@opraiz/ext-scripts",
  "version": "1.0.0",
  "license": "EPL-2.0 OR GPL-2.0-only WITH Classpath-exception-2.0",
  "description": "NPM scripts for OPRAIZ IDECODE packages.",
  "bin": {
    "run": "bin/opraiz-run.js",
    "opraizext": "bin/opraiz-ext.js",
    "opraiz-ts-clean": "bin/opraiz-ts-clean.js"
  },
  "opraiz-monorepo-scripts": {
    "ext:clean": "opraizext compile:clean && opraizext lint:clean && opraizext test:clean",
    "ext:build": "opraiz-ts-clean && tsc --build",
    "ext:compile": "opraiz-ts-clean && tsc --project .",
    "ext:compile:clean": "rimraf lib *.tsbuildinfo",
    "ext:lint": "eslint --cache=true --no-error-on-unmatched-pattern=true \"{src,test}/**/*.{ts,tsx}\"",
    "ext:lint:clean": "rimraf .eslintcache",
    "ext:watch": "concurrently --kill-others -n cleanup,tsc -c magenta,red \"opraiz-ts-clean -w\" \"tsc -b -w --preserveWatchOutput\"",
    "ext:watch:fast": "tsc -p -w",
    "ext:test": "nyc mocha --config ../../configs/mocharc.yml \"./lib/**/*.*spec.js\"",
    "ext:test:watch": "mocha -w --config ../../configs/mocharc.yml \"./lib/**/*.*spec.js\"",
    "ext:test:clean": "rimraf .nyc_output coverage"
  }
}
