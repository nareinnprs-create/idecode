{
  "private": true,
  "name": "@opraiz/example-electron",
  "productName": "OPRAIZ IDECODE Electron Example",
  "version": "1.0.0",
  "main": "lib/backend/electron-main.js",
  "license": "EPL-2.0 OR GPL-2.0-only WITH Classpath-exception-2.0",
  "theia": {
    "target": "electron",
    "frontend": {
      "config": {
        "applicationName": "OPRAIZ IDECODE Electron Example",
        "reloadOnReconnect": true,
        "electron": {
          "splashScreenOptions": {
            "content": "resources/opraiz-logo.svg",
            "height": 90
          }
        }
      }
    },
    "backend": {
      "config": {
        "frontendConnectionTimeout": -1
      }
    }
  },
  "dependencies": {
    "@opraiz/ai-anthropic": "1.0.0",
    "@opraiz/ai-chat": "1.0.0",
    "@opraiz/ai-chat-ui": "1.0.0",
