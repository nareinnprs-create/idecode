{
  "private": true,
  "name": "@opraiz/example-browser-only",
  "version": "1.72.0",
  "license": "EPL-2.0 OR GPL-2.0-only WITH Classpath-exception-2.0",
  "theia": {
    "target": "browser-only",
    "frontend": {
      "config": {
        "applicationName": "OPRAIZ IDECODE Browser-Only Example",
        "preferences": {
          "files.enableTrash": false
        }
      }
    }
  },
  "dependencies": {
    "@opraiz/ai-chat": "1.72.0",
    "@opraiz/ai-chat-ui": "1.72.0",
    "@opraiz/ai-code-completion": "1.72.0",
    "@opraiz/ai-core": "1.72.0",
    "@opraiz/ai-core-ui": "1.72.0",
    "@opraiz/ai-history": "1.72.0",
    "@opraiz/ai-ollama": "1.72.0",
    "@opraiz/ai-openai": "1.72.0",
    "@opraiz/ai-scanoss": "1.72.0",
    "@opraiz/api-samples": "1.72.0",
    "@opraiz/bulk-edit": "1.72.0",
    "@opraiz/callhierarchy": "1.72.0",
    "@opraiz/collaboration": "1.72.0",
    "@opraiz/console": "1.72.0",
    "@opraiz/core": "1.72.0",
    "@opraiz/debug": "1.72.0",
    "@opraiz/editor": "1.72.0",
    "@opraiz/editor-preview": "1.72.0",
    "@opraiz/file-search": "1.72.0",
    "@opraiz/filesystem": "1.72.0",
    "@opraiz/getting-started": "1.72.0",
    "@opraiz/keymaps": "1.72.0",
    "@opraiz/markers": "1.72.0",
    "@opraiz/memory-inspector": "1.72.0",
    "@opraiz/messages": "1.72.0",
    "@opraiz/metrics": "1.72.0",
    "@opraiz/mini-browser": "1.72.0",
    "@opraiz/monaco": "1.72.0",
    "@opraiz/navigator": "1.72.0",
    "@opraiz/outline-view": "1.72.0",
    "@opraiz/output": "1.72.0",
    "@opraiz/plugin-dev": "1.72.0",
    "@opraiz/plugin-ext": "1.72.0",
    "@opraiz/plugin-ext-vscode": "1.72.0",
    "@opraiz/plugin-metrics": "1.72.0",
    "@opraiz/preferences": "1.72.0",
    "@opraiz/preview": "1.72.0",
    "@opraiz/process": "1.72.0",
    "@opraiz/property-view": "1.72.0",
    "@opraiz/scanoss": "1.72.0",
    "@opraiz/scm": "1.72.0",
    "@opraiz/scm-extra": "1.72.0",
    "@opraiz/search-in-workspace": "1.72.0",
    "@opraiz/secondary-window": "1.72.0",
    "@opraiz/task": "1.72.0",
    "@opraiz/terminal": "1.72.0",
    "@opraiz/timeline": "1.72.0",
    "@opraiz/toolbar": "1.72.0",
    "@opraiz/typehierarchy": "1.72.0",
    "@opraiz/userstorage": "1.72.0",
    "@opraiz/variable-resolver": "1.72.0",
    "@opraiz/vsx-registry": "1.72.0",
    "@opraiz/workspace": "1.72.0"
  },
  "scripts": {
    "prepare:no-native": "lerna run prepare --scope=\"@opraiz/re-exports\" && lerna run generate-opraiz-re-exports --scope=\"@opraiz/core\"",
    "clean": "opraizext clean",
    "build": "opraizext build && npm run -s bundle",
    "bundle": "opraiz build --mode development",
    "compile": "opraizext compile",
    "start": "opraiz start",
    "start:debug": "npm run -s start -- --log-level=debug",
    "start:watch": "concurrently --kill-others -n tsc,bundle,run -c red,yellow,green \"tsc -b -w --preserveWatchOutput\" \"npm run -s watch:bundle\" \"npm run -s start\"",
    "watch": "concurrently --kill-others -n tsc,bundle -c red,yellow \"tsc -b -w --preserveWatchOutput\" \"npm run -s watch:bundle\"",
    "watch:bundle": "opraiz build --watch --mode development",
    "watch:compile": "tsc -b -w"
  },
  "devDependencies": {
    "@opraiz/cli": "1.72.0"
  }
}
