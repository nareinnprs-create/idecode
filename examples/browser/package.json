{
  "private": true,
  "name": "@opraiz/example-browser",
  "version": "1.0.0",
  "license": "EPL-2.0 OR GPL-2.0-only WITH Classpath-exception-2.0",
  "theia": {
    "frontend": {
      "config": {
        "applicationName": "OPRAIZ IDECODE Browser Example",
        "preferences": {
          "files.enableTrash": false,
          "security.workspace.trust.enabled": false
        },
        "reloadOnReconnect": true,
        "favicon": "favicon.svg"
      }
    },
    "backend": {
      "config": {
        "frontendConnectionTimeout": 3000
      }
    }
  },
  "theiaPluginsDir": "../../plugins",
  "dependencies": {
    "@opraiz/ai-anthropic": "1.0.0",
    "@opraiz/ai-chat": "1.0.0",
    "@opraiz/ai-chat-ui": "1.0.0",
